{
  "name": "@macro/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "start": "concurrently -n workspace,angular,react,fdc3 -c blue,green,yellow,magenta \"nx serve macro-workspace\" \"nx serve macro-angular\" \"nx serve macro-react\" \"nx serve macro-angular-fdc3\"",
    "start:workspace": "nx serve macro-workspace",
    "start:angular": "nx serve macro-angular",
    "start:react": "nx serve macro-react",
    "start:fdc3": "nx serve macro-angular-fdc3",
    "serve:workspace": "nx serve macro-workspace",
    "serve:angular": "nx serve macro-angular",
    "serve:react": "nx serve macro-react",
    "build:workspace": "nx build macro-workspace",
    "build:angular": "nx build macro-angular",
    "build:react": "nx build macro-react",
    "build:fdc3": "nx build macro-angular-fdc3",
    "build:logger": "nx build logger",
    "build:mcp": "nx build macro-mcp",
    "build:mcp-agent": "nx build macro-mcp-agent && node -e \"const f=require('fs'),p=JSON.parse(f.readFileSync('dist/apps/macro-mcp-agent/package.json','utf8'));p.dependencies.amps=JSON.parse(f.readFileSync('node_modules/amps/package.json','utf8')).version;f.writeFileSync('dist/apps/macro-mcp-agent/package.json',JSON.stringify(p,null,2))\"",
    "start:mcp-agent": "nx serve macro-mcp-agent",
    "publish:logger": "npm run build:logger && npm publish --prefix dist/libs/logger",
    "publish:logger:dry-run": "npm run build:logger && npm publish --prefix dist/libs/logger --dry-run",
    "launch": "node apps/macro-workspace/launch.mjs http://localhost:4202/local/manifest.fin.json",
    "launch:openshift": "echo 'Update OPENSHIFT_WORKSPACE_HOST in openshift/manifest.fin.json then run: node apps/macro-workspace/launch.mjs https://<OPENSHIFT_WORKSPACE_HOST>/openshift/manifest.fin.json'",
    "e2e:angular": "nx e2e macro-angular-e2e",
    "e2e:angular:headed": "nx e2e macro-angular-e2e --headed",
    "e2e:angular:ui": "nx e2e macro-angular-e2e --ui",
    "e2e:angular:debug": "nx e2e macro-angular-e2e --debug",
    "e2e:angular:chromium": "nx e2e macro-angular-e2e --project=chromium",
    "e2e:angular:firefox": "nx e2e macro-angular-e2e --project=firefox",
    "e2e:angular:webkit": "nx e2e macro-angular-e2e --project=webkit",
    "e2e:react": "nx e2e macro-react-e2e",
    "e2e:react:headed": "nx e2e macro-react-e2e --headed",
    "e2e:react:ui": "nx e2e macro-react-e2e --ui",
    "e2e:react:debug": "nx e2e macro-react-e2e --debug",
    "e2e:react:chromium": "nx e2e macro-react-e2e --project=chromium",
    "e2e:react:firefox": "nx e2e macro-react-e2e --project=firefox",
    "e2e:react:webkit": "nx e2e macro-react-e2e --project=webkit",
    "test:ci": "nx run-many --target=test --exclude=macro-react,macro-react-grid --configuration=ci && nx run-many --target=test --projects=macro-react,macro-react-grid --coverage",
    "e2e:workspace": "nx e2e macro-workspace-e2e",
    "e2e:workspace:headed": "nx e2e macro-workspace-e2e --headed",
    "e2e:workspace:ui": "nx e2e macro-workspace-e2e --ui",
    "e2e:workspace:debug": "nx e2e macro-workspace-e2e --debug",
    "e2e:workspace:openfin": "nx e2e macro-workspace-e2e --project=openfin",
    "build": "nx run-many --target=build --all",
    "buildAll": "nx run-many --target=build --all",
    "build:apps": "nx run-many --target=build --projects=macro-angular,macro-react,macro-workspace,macro-angular-fdc3,market-data-server,macro-mcp,risk-overview,rfq-butterfly-ticket,capital-markets-themes,rates-execution-blotter",
    "build:libs": "nx run-many --target=build --projects=logger,amps,solace,nats,transports,openfin,macro-design,macro-angular-grid,macro-react-grid,rxutils",
    "test": "nx run-many --target=test --all",
    "start:risk-overview": "nx serve risk-overview",
    "build:risk-overview": "nx build risk-overview",
    "start:rfq-butterfly-ticket": "nx serve rfq-butterfly-ticket",
    "build:rfq-butterfly-ticket": "nx build rfq-butterfly-ticket",
    "start:capital-markets-themes": "nx serve capital-markets-themes",
    "build:capital-markets-themes": "nx build capital-markets-themes",
    "start:rates-execution-blotter": "nx serve rates-execution-blotter",
    "build:rates-execution-blotter": "nx build rates-execution-blotter"
  },
