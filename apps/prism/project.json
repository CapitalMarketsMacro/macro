{
  "name": "prism",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/prism/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "dist/apps/prism",
        "browser": "apps/prism/src/main.ts",
        "polyfills": ["zone.js"],
        "tsConfig": "apps/prism/tsconfig.app.json",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/prism/public"
          }
        ],
        "styles": ["apps/prism/src/styles.css"]
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "5mb",
              "maximumError": "8mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      }
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "defaultConfiguration": "development",
      "options": {
        "port": 4204
      },
      "configurations": {
        "production": {
          "buildTarget": "prism:build:production"
        },
        "development": {
          "buildTarget": "prism:build:development"
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": [
        "{workspaceRoot}/coverage/{projectRoot}",
        "{workspaceRoot}/reports/{projectName}-junit.xml"
      ],
      "options": {
        "jestConfig": "apps/prism/jest.config.cts",
        "tsConfig": "apps/prism/tsconfig.spec.json"
      }
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "prism:build",
        "port": 4204,
        "staticFilePath": "dist/apps/prism/browser",
        "spa": true
      }
    }
  }
}
