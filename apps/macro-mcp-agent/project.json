{
  "name": "macro-mcp-agent",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/macro-mcp-agent/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "platform": "node",
        "outputPath": "dist/apps/macro-mcp-agent",
        "format": ["cjs"],
        "bundle": true,
        "main": "apps/macro-mcp-agent/src/main.ts",
        "tsConfig": "apps/macro-mcp-agent/tsconfig.app.json",
        "assets": [],
        "generatePackageJson": true,
        "esbuildOptions": {
          "sourcemap": true,
          "outExtension": { ".js": ".js" },
          "external": ["amps"]
        }
      },
      "configurations": {
        "development": {},
        "production": {
          "esbuildOptions": {
            "sourcemap": false,
            "outExtension": { ".js": ".js" },
            "external": ["amps"]
          }
        }
      }
    },
    "serve": {
      "continuous": true,
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "dependsOn": ["build"],
      "options": {
        "buildTarget": "macro-mcp-agent:build",
        "runBuildTargetDependencies": false
      },
      "configurations": {
        "development": {
          "buildTarget": "macro-mcp-agent:build:development"
        },
        "production": {
          "buildTarget": "macro-mcp-agent:build:production"
        }
      }
    }
  },
  "tags": []
}
