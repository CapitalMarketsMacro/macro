{

  "devtools_port": 9090,

  "licenseKey": "openfin-demo-license-key",

  "runtime": {

    "arguments": "--v=1 --inspect --enable-mesh --security-realm=macro-workspace",

    "version": "44.146.101.5"

  },

  "platform": {

    "uuid": "macro-workspace-platform",

    "name": "Macro Workspace",

    "description": "Capital Markets Desktop Workspace Platform",

    "icon": "http://localhost:4202/favicon.ico",

    "autoShow": true,

    "allowLaunchIntoPlatform": true,

    "providerUrl": "http://localhost:4202/provider?env=local",

    "preventQuitOnLastWindowClosed": false,

    "appLogsTimezone": "utc",

    "enableAppLogging": true,

    "logManagement": {

      "enabled": true,

      "url": "http://MontyUbuntu2604:8000"

    },

    "defaultWindowOptions": {

      "icon": "http://localhost:4202/favicon.ico",

      "taskbarIcon": "http://localhost:4202/favicon.ico",

      "taskbarIconGroup": "macro-workspace"

    },

    "defaultViewOptions": {

      "icon": "http://localhost:4202/MacroThemeCondensed/assets/favicon.svg"

    },

    "defaultWidth": 280,

    "defaultHeight": 280,

    "minWidth": 280,

    "minHeight": 280,

    "maxWidth": 280,

    "maxHeight": 600,

    "resizable": false,

    "frame": false,

    "alwaysOnTop": true,

    "showTaskbarIcon": false,

    "cornerRounding": {

      "width": 12,

      "height": 12

    },

    "shadow": true,

    "saveWindowState": false,

    "permissions": {

      "System": {

        "getOSInfo": true,

        "launchExternalProcess": {

          "enabled": true,

          "assets": {

            "enabled": true,

            "srcRules": [

              {

                "match": [

                  "https://cdn.openfin.co/release/snap/*"

                ],

                "behavior": "allow"

              }

            ]

          },

          "downloads": {

            "enabled": true

          },

          "executables": {

            "enabled": true

          }

        },

        "terminateExternalProcess": true,

        "downloadAsset": true,

        "serveAsset": true,

        "openUrlWithBrowser": {

          "enabled": true,

          "protocols": [

            "http",

            "https",

            "mailto"

          ]

        },

        "readRegistryValue": true,

        "registerCustomProtocol": true,

        "unregisterCustomProtocol": true,

        "checkCustomProtocolState": true,

        "launchLogUploader": true

      },

      "Application": {

        "setFileDownloadLocation": true,

        "getFileDownloadLocation": true

      },

      "Clipboard": {

        "writeText": true,

        "readText": true,

        "writeHtml": true,

        "readHtml": true,

        "writeRtf": true,

        "readRtf": true,

        "writeImage": true,

        "readImage": true

      },

      "webAPIs": [

        "clipboard-read",

        "clipboard-sanitized-write",

        "notifications",

        "openExternal",

        "fullscreen"

      ]

    }

  },

  "appAssets": [

    {

      "src": "https://cdn.openfin.co/release/snap/1.6.0/snap.zip",

      "alias": "openfin-snap",

      "version": "1.6.0",

      "target": "OpenFinSnap.exe"

    }

  ],

  "shortcut": {

    "company": "Macro Workspace",

    "description": "A way of showing examples of what Macro Workspace can do.",

    "icon": "http://localhost:4202/favicon.ico",

    "name": "Macro Workspace Starter",

    "target": [

      "desktop",

      "start-menu"

    ]

  },

  "supportInformation": {

    "company": "Macro Workspace",

    "product": "Workspace Starter - Macro Workspace",

    "email": "support@macroworkspace.co",

    "forwardErrorReports": true

  }

}
