{
  "devtools_port": 9090,
  "licenseKey": "openfin-demo-license-key",
  "runtime": {
    "arguments": "--v=1 --inspect",
    "version": "43.142.101.2"
  },
  "platform": {
    "uuid": "macro-workspace-platform",
    "icon": "http://localhost:4202/icons/platform.svg",
    "autoShow": true,
    "allowLaunchIntoPlatform": true,
    "providerUrl": "http://localhost:4202/provider",
    "preventQuitOnLastWindowClosed": false,
    "defaultWidth": 240,
    "defaultHeight": 280,
    "minWidth": 240,
    "minHeight": 280,
    "maxWidth": 240,
    "maxHeight": 440,
    "resizable": false,
    "frame": false,
    "alwaysOnTop": true,
    "showTaskbarIcon": false,
    "cornerRounding": { "width": 12, "height": 12 },
    "shadow": true,
    "saveWindowState": false,
    "permissions": {
      "System": {
        "getOSInfo": true,
        "launchExternalProcess": {
          "enabled": true,
          "assets": {
            "enabled": true,
            "srcRules": [
              {
                "match": ["https://cdn.openfin.co/release/snap/*"],
                "behavior": "allow"
              }
            ]
          },
          "downloads": {
            "enabled": true
          },
          "executables": {
            "enabled": true
          }
        },
        "terminateExternalProcess": true,
        "downloadAsset": true,
        "serveAsset": true,
        "openUrlWithBrowser": {
          "enabled": true,
          "protocols": ["http", "https", "mailto"]
        },
        "readRegistryValue": true,
        "registerCustomProtocol": true,
        "unregisterCustomProtocol": true,
        "checkCustomProtocolState": true,
        "launchLogUploader": true
      },
      "Application": {
        "setFileDownloadLocation": true,
        "getFileDownloadLocation": true
      },
      "Clipboard": {
        "writeText": true,
        "readText": true,
        "writeHtml": true,
        "readHtml": true,
        "writeRtf": true,
        "readRtf": true,
        "writeImage": true,
        "readImage": true
      },
      "webAPIs": [
        "clipboard-read",
        "clipboard-sanitized-write",
        "notifications",
        "openExternal",
        "fullscreen"
      ]
    }
  },
  "appAssets": [
    {
      "src": "https://cdn.openfin.co/release/snap/1.5.0/snap.zip",
      "alias": "openfin-snap",
      "version": "1.5.0",
      "target": "OpenFinSnap.exe"
    }
  ],
  "shortcut": {
    "company": "OpenFin",
    "description": "A way of showing examples of what OpenFin can do.",
    "icon": "http://localhost:4202/icons/platform.svg",
    "name": "Macro Workspace Starter",
    "target": ["desktop", "start-menu"]
  },
  "supportInformation": {
    "company": "OpenFin",
    "product": "Workspace Starter - Macro Workspace",
    "email": "support@openfin.co",
    "forwardErrorReports": true
  },
  "customSettings": {
    "apps": [
