{
  "name": "@macro/openfin",
  "version": "0.0.1",
  "description": "OpenFin workspace platform services and utilities for Angular and React applications",
  "keywords": [
    "openfin",
    "workspace",
    "platform",
    "fdc3",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "main": "./src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.js"
    },
    "./react": {
      "types": "./src/lib/react.d.ts",
      "default": "./src/lib/react.js"
    },
    "./theme-sync": {
      "types": "./src/lib/theme-sync.d.ts",
      "default": "./src/lib/theme-sync.js"
    }
  },
  "files": [
    "src/**/*",
    "README.md",
    "package.json"
  ],
  "repository": {
    "type": "git",
    "url": ""
  },
  "dependencies": {
    "@finos/fdc3": "2.2.3",
    "@openfin/core": "44.101.5",
    "@openfin/workspace": "24.0.19",
    "@openfin/workspace-platform": "24.0.19",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "peerDependencies": {
    "@macro/logger": "*"
  },
  "peerDependenciesMeta": {}
}

