{
  "name": "macro-grid-format",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/macro-grid-format/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/macro-grid-format",
        "main": "libs/macro-grid-format/src/index.ts",
        "tsConfig": "libs/macro-grid-format/tsconfig.lib.json",
        "assets": ["libs/macro-grid-format/*.md"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": [
        "{workspaceRoot}/coverage/{projectRoot}",
        "{workspaceRoot}/reports/{projectName}-junit.xml"
      ],
      "options": {
        "jestConfig": "libs/macro-grid-format/jest.config.ts"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
